{
  "name": "toolspec",
  "version": "0.1.0",
  "description": "Open LLM Tool Specification — vendor-agnostic standard for publishing LLM-consumable tool services over HTTP",
  "type": "module",
  "bin": {
    "toolspec": "./dist/cli/index.js"
  },
  "main": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./cli": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "validate": "tsx src/cli/index.ts validate",
    "connect": "tsx src/cli/index.ts connect"
  },
  "keywords": [
    "llm",
    "tools",
    "mcp",
    "openapi",
    "ai",
    "function-calling",
    "agent",
    "specification"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ajv": "^8.17.0",
    "commander": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
